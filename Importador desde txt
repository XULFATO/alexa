Option Explicit

Sub ImportarArchivoAnchoFijo_Corregido()
    Dim rutaArchivo As Variant
    Dim linea As String
    Dim empID As String, empIDPrevio As String
    Dim nombreCol As String, valorCol As String
    Dim filaDestino As Long, colDestino As Long
    Dim ws As Worksheet
    Dim dicColumnas As Object
    
    ' 1. Selección de archivo
    rutaArchivo = Application.GetOpenFilename("Archivos de texto (*.txt; *.dat), *.txt; *.dat", , "Seleccione el fichero")
    If rutaArchivo = False Then Exit Sub
    
    ' 2. Preparar Hoja "Page 1 v1"
    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets("Page 1 v1")
    On Error GoTo 0
    
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
        ws.Name = "Page 1 v1"
    Else
        ws.Cells.Clear
    End If
    
    ' Formato texto GLOBAL para evitar que 000001 sea 1
    ws.Cells.NumberFormat = "@"
    
    Set dicColumnas = CreateObject("Scripting.Dictionary")
    ' Reservamos la columna 1 para el ID
    dicColumnas.Add "EMPLOYEE_ID", 1
    ws.Cells(1, 1).Value = "EMPLOYEE_ID"
    
    filaDestino = 1 ' Empezaremos en la 2
    empIDPrevio = ""
    
    ' 3. Lectura
    Open rutaArchivo For Input As #1
    
    Do While Not EOF(1)
        Line Input #1, linea
        
        ' IMPORTANTE: Verificamos que la línea sea larga (mínimo hasta la cabecera pos 150)
        If Len(linea) >= 154 Then
            
            ' Extraer y limpiar espacios y carácteres raros
            empID = Trim(Replace(Mid(linea, 11, 8), vbTab, ""))
            valorCol = Trim(Replace(Mid(linea, 25, 32), vbTab, ""))
            nombreCol = Trim(Replace(Mid(linea, 150, 5), vbTab, ""))
            
            ' Si la línea está vacía de datos reales, saltamos
            If empID = "" Then GoTo SiguienteLinea
            
            ' Lógica de cambio de fila (Nuevo Empleado)
            If empID <> empIDPrevio Then
                filaDestino = filaDestino + 1
                ws.Cells(filaDestino, 1).Value = empID
                empIDPrevio = empID
            End If
            
            ' Lógica de Columnas Dinámicas
            If nombreCol <> "" Then
                If Not dicColumnas.Exists(nombreCol) Then
                    ' Crear nueva cabecera si no existe
                    colDestino = dicColumnas.Count + 1
                    dicColumnas.Add nombreCol, colDestino
                    ws.Cells(1, colDestino).Value = nombreCol
                Else
                    ' Usar columna existente
                    colDestino = dicColumnas(nombreCol)
                End If
                
                ' Escribir el valor en la fila del empleado actual
                ws.Cells(filaDestino, colDestino).Value = valorCol
            End If
        End If
        
SiguienteLinea:
    Loop
    
    Close #1
    
    ' 4. Ajustes finales
    ws.Rows(1).Font.Bold = True
    ws.Columns.AutoFit
    
    MsgBox "Importación finalizada en 'Page 1 v1'." & vbCrLf & _
           "Filas: " & (filaDestino - 1) & vbCrLf & _
           "Columnas: " & dicColumnas.Count, vbInformation
End Sub

    ' Formateo final
    ws.Rows(1).Font.Bold = True
    ws.Columns.AutoFit
    
    MsgBox "Importación completada en la hoja 'Page 1 v1'", vbInformation
End Sub
